# ── Environnement Docker RAG-DPO ─────────────────────────────────────────────
# Copier ce fichier en .env et adapter les valeurs si besoin.
# Les valeurs par défaut correspondent au setup local (sans Docker).

# ── Ollama ────────────────────────────────────────────────────────────────────
# En local  : http://localhost:11434  (Ollama installé sur Windows)
# En Docker : http://ollama:11434     (conteneur frère, réseau Docker interne)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral-nemo

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
