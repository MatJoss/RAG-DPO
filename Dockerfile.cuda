# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.cuda — RAG-DPO Streamlit App (GPU variant)
# ─────────────────────────────────────────────────────────────────────────────
# Variante GPU pour faire tourner embeddings + reranker sur CUDA.
# Inclut flash-attn pour accélérer les modèles transformer (BGE-M3, reranker).
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
#
# Note: le build de flash-attn compile du C++/CUDA (~10 min la première fois).
# L'image NVIDIA fournit le CUDA toolkit nécessaire à la compilation.
# ─────────────────────────────────────────────────────────────────────────────

# Image NVIDIA avec CUDA toolkit (nécessaire pour compiler flash-attn)
FROM nvidia/cuda:12.6.3-devel-ubuntu22.04 AS base

# Empêcher les prompts interactifs pendant l'install
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Installer Python 3.11 + dépendances système
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    build-essential \
    curl \
    git \
    ninja-build \
    && rm -rf /var/lib/apt/lists/*

# Faire de Python 3.11 le défaut
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# Mettre à jour pip
RUN python -m pip install --upgrade pip

# ── Dossier de travail ───────────────────────────────────────────────────────
WORKDIR /app

# ── Dépendances Python (couche cachée si requirements.txt ne change pas) ────
COPY requirements.txt .

# Installer PyTorch avec CUDA 12.6 (~2 GB)
RUN pip install --no-cache-dir torch==2.10.0 --index-url https://download.pytorch.org/whl/cu126

# Installer le reste des dépendances
RUN pip install --no-cache-dir -r requirements.txt

# Installer flash-attn (compilation C++/CUDA, ~10 min)
# MAX_JOBS=4 pour éviter OOM pendant la compilation
# --no-build-isolation car torch doit être visible pendant la compilation
ENV MAX_JOBS=4
RUN pip install --no-cache-dir flash-attn --no-build-isolation

# ── Code source ──────────────────────────────────────────────────────────────
COPY . .

# Rendre l'entrypoint exécutable
RUN chmod +x /app/scripts/entrypoint.sh

# ── Variables d'environnement par défaut ─────────────────────────────────────
ENV OLLAMA_BASE_URL=http://ollama:11434
ENV OLLAMA_MODEL=mistral-nemo
ENV PROJECT_ROOT=/app
ENV AUTO_DOWNLOAD_DB=true

# ── Port Streamlit ───────────────────────────────────────────────────────────
EXPOSE 8501

# ── Healthcheck ──────────────────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

# ── Commande de lancement ────────────────────────────────────────────────────
ENTRYPOINT ["/app/scripts/entrypoint.sh"]
