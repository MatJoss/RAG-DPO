# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.cuda — RAG-DPO Streamlit App (GPU variant)
# ─────────────────────────────────────────────────────────────────────────────
# Multi-stage build :
#   Stage 1 (flash-builder) : compile flash-attn (~1h, caché tant que torch
#            ne change pas → rebuild de l'app quasi-instantané)
#   Stage 2 (app)           : installe requirements + code source
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# Stage 1 — Compiler flash-attn (couche lourde, rarement invalidée)
# ═════════════════════════════════════════════════════════════════════════════
FROM nvidia/cuda:12.6.3-devel-ubuntu22.04 AS flash-builder

ENV DEBIAN_FRONTEND=noninteractive

# Python 3.11 via deadsnakes
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3.11-dev python3-pip \
    build-essential git ninja-build \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1
RUN python -m pip install --upgrade pip

# Installer torch (nécessaire pour compiler flash-attn)
RUN pip install --no-cache-dir torch==2.10.0 --index-url https://download.pytorch.org/whl/cu126

# Dépendances de build requises par flash-attn setup.py
RUN pip install --no-cache-dir packaging setuptools wheel

# Compiler flash-attn → wheel dans /wheels/
# MAX_JOBS=2 pour éviter OOM/crash WSL (~1h de compilation)
ENV MAX_JOBS=2
RUN pip wheel --no-cache-dir --no-build-isolation --wheel-dir=/wheels flash-attn


# ═════════════════════════════════════════════════════════════════════════════
# Stage 2 — Image finale de l'application
# ═════════════════════════════════════════════════════════════════════════════
FROM nvidia/cuda:12.6.3-devel-ubuntu22.04 AS app

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Python 3.11 + dépendances système
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3.11-dev python3-pip \
    build-essential curl git ninja-build \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# Supprimer les packages système distutils qui bloquent pip (blinker, etc.)
RUN rm -rf /usr/lib/python3/dist-packages/blinker* \
           /usr/lib/python3/dist-packages/blinker-*.egg-info

RUN python -m pip install --upgrade pip

# ── Dossier de travail ───────────────────────────────────────────────────────
WORKDIR /app

# ── Dépendances Python ──────────────────────────────────────────────────────
COPY requirements.txt .

# PyTorch CUDA 12.6
RUN pip install --no-cache-dir torch==2.10.0 --index-url https://download.pytorch.org/whl/cu126

# Dépendances de l'app
RUN pip install --no-cache-dir -r requirements.txt

# Flash-attn : copier le wheel pré-compilé du stage 1 (instantané)
COPY --from=flash-builder /wheels /tmp/wheels
RUN pip install --no-cache-dir /tmp/wheels/*.whl && rm -rf /tmp/wheels

# ── Code source ──────────────────────────────────────────────────────────────
COPY . .
RUN chmod +x /app/scripts/entrypoint.sh

# ── Variables d'environnement par défaut ─────────────────────────────────────
ENV OLLAMA_BASE_URL=http://ollama:11434
ENV OLLAMA_MODEL=mistral-nemo
ENV PROJECT_ROOT=/app
ENV AUTO_DOWNLOAD_DB=true

# ── Port Streamlit ───────────────────────────────────────────────────────────
EXPOSE 8501

# ── Healthcheck ──────────────────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

# ── Commande de lancement ────────────────────────────────────────────────────
ENTRYPOINT ["/app/scripts/entrypoint.sh"]
